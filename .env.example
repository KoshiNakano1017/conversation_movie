# ============================================================
# ConversationMovie 環境変数設定
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --------------------------------------------------
# App
# --------------------------------------------------
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-this-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# --------------------------------------------------
# Supabase
# https://app.supabase.com のプロジェクト設定から取得
# --------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase PostgreSQL 直接接続URL（Alembicマイグレーション用）
# Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --------------------------------------------------
# Gemini API
# https://aistudio.google.com/app/apikey から取得
# --------------------------------------------------
GEMINI_API_KEY=AIzaSy...

# --------------------------------------------------
# YouTube Data API v3
# https://console.cloud.google.com で OAuth 2.0 クライアントIDを作成
# --------------------------------------------------
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# --------------------------------------------------
# Redis
# --------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------
# Whisper
# モデルサイズ: tiny, base, small, medium, large-v3
# デバイス: cpu, cuda (GPU使用時)
# --------------------------------------------------
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_MODEL_DIR=/app/models

# --------------------------------------------------
# Storage
# --------------------------------------------------
MEDIA_DIR=/app/media
MAX_UPLOAD_SIZE_MB=500

# --------------------------------------------------
# Shotstack（動画レンダリング API・推奨）
# https://dashboard.shotstack.io/ → API Keys → Stage キー
# SHOTSTACK_ENV: stage（開発・透かしあり）| production（本番・有料）
# --------------------------------------------------
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# --------------------------------------------------
# Remotion（レガシー・未使用）
# --------------------------------------------------
REMOTION_PROJECT_PATH=/remotion
NODE_PATH=/usr/bin/node

# --------------------------------------------------
# 外部 CLI（Windows: PATH が Celery ワーカーに届かない場合の絶対パス）
# winget install Gyan.FFmpeg 後の例:
# FFMPEG_PATH=C:/Users/<user>/AppData/Local/Microsoft/WinGet/Packages/.../bin/ffmpeg.exe
# NPX_PATH=C:/Program Files/nodejs/npx.cmd
# --------------------------------------------------
FFMPEG_PATH=
NPX_PATH=
